# URL de conexión con pgBouncer (Transaction mode) — para la app en producción
# Agrega ?pgbouncer=true&connection_limit=1 al final
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# URL directa sin pgBouncer — usada por Prisma para migraciones
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Secret JWT (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambia-este-valor-por-uno-seguro-de-al-menos-32-chars

# Duración del token en segundos (86400 = 24 horas)
JWT_EXPIRES_IN=86400
