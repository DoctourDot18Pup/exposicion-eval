generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  docente
  alumno
}

model Usuario {
  id            String   @id @default(cuid())
  username      String   @unique
  password_hash String
  rol           Rol
  createdAt     DateTime @default(now())

  grupos        Grupo[]  @relation("DocenteGrupos")

  @@map("usuarios")
}

model Materia {
  id             String   @id @default(cuid())
  clave_materia  String   @unique
  nombre_materia String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  grupos         Grupo[]

  @@map("materias")
}

model Grupo {
  id           String   @id @default(cuid())
  nombre_grupo String
  materiaId    String
  docenteId    String?
  materia      Materia  @relation(fields: [materiaId], references: [id])
  docente      Usuario? @relation("DocenteGrupos", fields: [docenteId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("grupos")
}
