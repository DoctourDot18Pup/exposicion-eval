generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  docente
  alumno
}

model Usuario {
  id            String   @id @default(cuid())
  username      String   @unique
  password_hash String
  rol           Rol
  createdAt     DateTime @default(now())

  grupos        Grupo[]  @relation("DocenteGrupos")

  @@map("usuarios")
}

model Materia {
  id             String   @id @default(cuid())
  clave_materia  String   @unique
  nombre_materia String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  grupos         Grupo[]

  @@map("materias")
}

model Grupo {
  id           String   @id @default(cuid())
  nombre_grupo String
  materiaId    String
  docenteId    String?
  materia      Materia  @relation(fields: [materiaId], references: [id])
  docente      Usuario? @relation("DocenteGrupos", fields: [docenteId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  alumnos      Alumno[]
  equipos      Equipo[]
  exposiciones Exposicion[]

  @@map("grupos")
}

model Alumno {
  id        String   @id @default(cuid())
  nombre    String
  apellido  String
  matricula String   @unique
  grupoId   String
  grupo     Grupo    @relation(fields: [grupoId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipos   AlumnoEquipo[]

  @@map("alumnos")
}

model Equipo {
  id            String   @id @default(cuid())
  nombre_equipo String
  grupoId       String
  grupo         Grupo    @relation(fields: [grupoId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  miembros      AlumnoEquipo[]
  exposiciones  Exposicion[]

  @@map("equipos")
}

model Exposicion {
  id        String   @id @default(cuid())
  tema      String
  fecha     DateTime
  equipoId  String
  grupoId   String
  equipo    Equipo   @relation(fields: [equipoId], references: [id])
  grupo     Grupo    @relation(fields: [grupoId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rubrica   Rubrica?

  @@map("exposiciones")
}

model Rubrica {
  id           String     @id @default(cuid())
  nombre       String
  descripcion  String?
  exposicionId String     @unique
  exposicion   Exposicion @relation(fields: [exposicionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  criterios    Criterio[]

  @@map("rubricas")
}

model Criterio {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  ponderacion Decimal  @db.Decimal(5, 2)
  rubricaId   String
  rubrica     Rubrica  @relation(fields: [rubricaId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("criterios")
}

model AlumnoEquipo {
  alumnoId String
  equipoId String
  alumno   Alumno @relation(fields: [alumnoId], references: [id])
  equipo   Equipo @relation(fields: [equipoId], references: [id])

  @@id([alumnoId, equipoId])
  @@unique([alumnoId])
  @@map("alumno_equipo")
}
